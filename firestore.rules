rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId && request.auth.token.email_verified == true; }

    // Phase 4: Validation helpers

    function isValidAgent(data) {
      let required = ['name', 'role', 'status', 'userId', 'createdAt'];
      return data.keys().hasAll(required)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role is string && data.role.size() > 0 && data.role.size() <= 100
        && data.status is string && data.status in ['Active', 'Draft']
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        // Optional fields
        && ( ('description' in data) ? (data.description is string && data.description.size() <= 1000) : true )
        && ( ('avatarColor' in data) ? (data.avatarColor is string && data.avatarColor.size() <= 50) : true )
        && ( ('basePrompt' in data) ? (data.basePrompt is string && data.basePrompt.size() <= 5000) : true )
        && ( ('memory' in data) ? (data.memory is string && data.memory.size() <= 50) : true )
        && ( ('successRate' in data) ? (data.successRate is string && data.successRate.size() <= 50) : true )
        && ( ('conversations' in data) ? (data.conversations is number) : true )
        && ( ('channels' in data) ? (data.channels is list && data.channels.size() <= 10) : true );
    }

    function isValidCandidate(data) {
      let required = ['name', 'role', 'stage', 'userId', 'createdAt'];
      let stages = ["Nuevo", "Contactado", "Espera de respuesta", "Cita agendada", "Confirmó asistencia", "Entrevista realizada", "No asistió", "Reagendar", "DDO y bienvenida", "En capacitación", "Contratado", "Rechazado"];
      return data.keys().hasAll(required)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.role is string && data.role.size() > 0 && data.role.size() <= 200
        && data.stage is string && data.stage in stages
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        // Optional fields
        && ( ('email' in data) ? (data.email is string && data.email.size() <= 200) : true )
        && ( ('phone' in data) ? (data.phone is string && data.phone.size() <= 50) : true )
        && ( ('source' in data) ? (data.source is string && data.source.size() <= 100) : true )
        && ( ('location' in data) ? (data.location is string && data.location.size() <= 200) : true )
        && ( ('experienceTime' in data) ? (data.experienceTime is string && data.experienceTime.size() <= 100) : true )
        && ( ('rating' in data) ? (data.rating is number) : true )
        && ( ('age' in data) ? (data.age is number) : true )
        && ( ('lastJob' in data) ? (data.lastJob is string && data.lastJob.size() <= 200) : true )
        && ( ('linkedin' in data) ? (data.linkedin is string && data.linkedin.size() <= 500) : true )
        && ( ('whatsapp' in data) ? (data.whatsapp is bool) : true )
        && ( ('appointment' in data) ? (
             data.appointment is map 
             && ( ('date' in data.appointment) ? data.appointment.date is string : true )
             && ( ('time' in data.appointment) ? data.appointment.time is string : true )
             && ( ('status' in data.appointment) ? data.appointment.status is string : true )
           ) : true );
    }

    function isValidJob(data) {
      let required = ['title', 'department', 'location', 'status', 'userId', 'createdAt'];
      return data.keys().hasAll(required)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.department is string && data.department.size() > 0 && data.department.size() <= 200
        && data.location is string && data.location.size() > 0 && data.location.size() <= 200
        && data.status is string && data.status in ['Active', 'Closed', 'Draft']
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        // Optional fields
        && ( ('applicants' in data) ? (data.applicants is number) : true )
        && ( ('platforms' in data) ? (data.platforms is list && data.platforms.size() <= 20) : true )
        && ( ('timeToHire' in data) ? (data.timeToHire is string && data.timeToHire.size() <= 100) : true );
    }

    function isValidLog(data) {
      let required = ['agent', 'action', 'type', 'date', 'time', 'userId', 'createdAt'];
      return data.keys().hasAll(required)
        && data.agent is string && data.agent.size() > 0 && data.agent.size() <= 100
        && data.action is string && data.action.size() > 0 && data.action.size() <= 1000
        && data.type is string && data.type in ["outreach", "screening", "match", "learning"]
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 20
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && ( ('agentId' in data) ? (data.agentId is string && data.agentId.size() <= 128) : true );
    }

    // Rules for agents
    match /agents/{agentId} {
      allow get: if isOwner(existing().userId) && isValidId(agentId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isOwner(incoming().userId) 
        && isValidId(agentId) 
        && isValidAgent(incoming()) 
        && incoming().createdAt == request.time
        && incoming().keys().size() <= 12;

      allow update: if isOwner(existing().userId) 
        && isValidId(agentId) 
        && isValidAgent(incoming()) 
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'status', 'description', 'channels', 'memory', 'conversations', 'successRate', 'avatarColor', 'basePrompt'])
        );

      allow delete: if isOwner(existing().userId) && isValidId(agentId);
    }

    // Rules for candidates
    match /candidates/{candidateId} {
      allow get: if isOwner(existing().userId) && isValidId(candidateId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isOwner(incoming().userId) 
        && isValidId(candidateId) 
        && isValidCandidate(incoming()) 
        && incoming().createdAt == request.time
        && incoming().keys().size() <= 16;

      allow update: if isOwner(existing().userId) 
        && isValidId(candidateId) 
        && isValidCandidate(incoming()) 
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'stage', 'email', 'phone', 'source', 'location', 'experienceTime', 'rating', 'age', 'lastJob', 'linkedin', 'whatsapp', 'appointment'])
        );

      allow delete: if isOwner(existing().userId) && isValidId(candidateId);
    }

    // Rules for jobs
    match /jobs/{jobId} {
      allow get: if isOwner(existing().userId) && isValidId(jobId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isOwner(incoming().userId) 
        && isValidId(jobId) 
        && isValidJob(incoming()) 
        && incoming().createdAt == request.time
        && incoming().keys().size() <= 9;

      allow update: if isOwner(existing().userId) 
        && isValidId(jobId) 
        && isValidJob(incoming()) 
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'department', 'location', 'status', 'applicants', 'platforms', 'timeToHire'])
        );

      allow delete: if isOwner(existing().userId) && isValidId(jobId);
    }

    // Rules for logs
    match /logs/{logId} {
      allow get: if isOwner(existing().userId) && isValidId(logId);
      allow list: if isOwner(resource.data.userId);
      
      allow create: if isOwner(incoming().userId) 
        && isValidId(logId) 
        && isValidLog(incoming()) 
        && incoming().createdAt == request.time
        && incoming().keys().size() <= 8;

      // Logs are generally immutable once created
      allow update: if false; 
      allow delete: if isOwner(existing().userId) && isValidId(logId);
    }
  }
}
